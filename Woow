{
  "name": "Ultra Beau Theme",
  "description": "Thème élégant bleu nuit et violet",
  "version": "2.0.0",
  "author": "Orinlo",
  "theme": {
    "colors": {
      "primary": "#1a1a2e",
      "secondary": "#16213e",
      "accent": "#e94560",
      "text": "#ffffff",
      "background": "#0f3460"
    },
    "fonts": {
      "main": "Poppins, sans-serif",
      "code": "Fira Code, monospace"
    },
    "background": {
      "image": "https://i.imgur.com/xtgygE7.jpeg",
      "opacity": 0.7,
      "blur": 3
    },
    "message": {
      "background": "#1e1e2f",
      "border": "1px solid #e94560",
      "border-radius": "15px",
      "padding": "10px",
      "box-shadow": "0 4px 15px rgba(0,0,0,0.3)"
    },
    "chat": {
      "input": {
        "background": "#0f3460",
        "color": "#ffffff",
        "border": "1px solid #e94560"
      }
    },
    "username": {
      "color": "#e94560",
      "font-weight": "bold"
    }
  }
}
